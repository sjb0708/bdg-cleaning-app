generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  password           String
  role               String    @default("CLEANER")
  phone              String?
  avatarUrl          String?
  bio                String?
  location           String?
  approved           Boolean   @default(false)
  emailNotifications Boolean   @default(true)
  appNotifications   Boolean   @default(true)
  inviteToken        String?   @unique
  inviteExpiry       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  properties        Property[]
  jobsAsAdmin       Job[]          @relation("AdminJobs")
  jobsAsCleaner     Job[]          @relation("CleanerJobs")
  notifications     Notification[]
  paymentsReceived  Payment[]      @relation("CleanerPayments")
  issueReports      IssueReport[]
  supplyRequests    SupplyRequest[]
}

model Property {
  id               String    @id @default(cuid())
  hostId           String
  name             String
  address          String
  city             String
  state            String
  bedrooms         Int
  bathrooms        Float
  description      String?
  imageUrl         String?
  airbnbIcalUrl    String?
  vrboIcalUrl      String?
  cleaningDuration     Int
  cleaningFee          Float     @default(0)
  accessInstructions   String?
  lastSyncedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  host              User               @relation(fields: [hostId], references: [id])
  jobs              Job[]
  bookings          Booking[]
  checklistTemplate ChecklistTemplate?
  payments          Payment[]
  issueReports      IssueReport[]
  supplyRequests    SupplyRequest[]
}

model Booking {
  id         String   @id @default(cuid())
  propertyId String
  platform   String
  externalId String?
  guestName  String?
  checkIn    DateTime
  checkOut   DateTime
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  jobs     Job[]

  @@unique([propertyId, externalId])
}

model Job {
  id            String    @id @default(cuid())
  propertyId    String
  hostId        String
  cleanerId     String?
  bookingId     String?
  status        String    @default("UNASSIGNED")
  scheduledDate DateTime
  duration      Int
  notes         String?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  property       Property        @relation(fields: [propertyId], references: [id])
  host           User            @relation("AdminJobs", fields: [hostId], references: [id])
  cleaner        User?           @relation("CleanerJobs", fields: [cleanerId], references: [id])
  booking        Booking?        @relation(fields: [bookingId], references: [id])
  checklistItems  ChecklistItem[]
  notifications   Notification[]
  payment         Payment?
  issueReports    IssueReport[]
  supplyRequests  SupplyRequest[]
}

model ChecklistTemplate {
  id         String                  @id @default(cuid())
  propertyId String                  @unique
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  property Property                @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  items    ChecklistTemplateItem[]
}

model ChecklistTemplateItem {
  id         String  @id @default(cuid())
  templateId String
  label      String
  room       String?
  order      Int     @default(0)

  template ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ChecklistItem {
  id        String  @id @default(cuid())
  jobId     String
  label     String
  completed Boolean @default(false)
  room      String?
  order     Int     @default(0)

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  jobId     String?
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job?  @relation(fields: [jobId], references: [id], onDelete: SetNull)
}

model IssueReport {
  id           String   @id @default(cuid())
  jobId        String
  propertyId   String
  reportedById String
  type         String   // DAMAGE, BROKEN_ITEM, STAIN, PEST, OTHER
  severity     String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  description  String
  status       String   @default("OPEN") // OPEN, REVIEWED, RESOLVED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  job        Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  property   Property      @relation(fields: [propertyId], references: [id])
  reportedBy User          @relation(fields: [reportedById], references: [id])
  photos     IssuePhoto[]
}

model IssuePhoto {
  id            String      @id @default(cuid())
  issueReportId String
  url           String
  createdAt     DateTime    @default(now())

  issueReport IssueReport @relation(fields: [issueReportId], references: [id], onDelete: Cascade)
}

model SupplyRequest {
  id            String   @id @default(cuid())
  jobId         String
  propertyId    String
  requestedById String
  items         String   // JSON array of supply names
  notes         String?
  status        String   @default("PENDING") // PENDING, ORDERED, DELIVERED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  property    Property @relation(fields: [propertyId], references: [id])
  requestedBy User     @relation(fields: [requestedById], references: [id])
}

model Payment {
  id          String    @id @default(cuid())
  jobId       String    @unique
  cleanerId   String
  propertyId  String
  amount      Float
  status      String    @default("UNPAID")
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  job      Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  cleaner  User     @relation("CleanerPayments", fields: [cleanerId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
}
